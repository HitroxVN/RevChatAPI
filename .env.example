# --- Cấu hình API ---
API_TITLE=RevChatAPI
API_VERSION=v1.1
DEFAULT_MODEL=easemate/gemini-2.0-flash

# --- Cấu hình Server ---
HOST=0.0.0.0
PORT=5000

# --- Bảo mật & Xác thực ---
REQUIRE_AUTH=true

# Key dùng để truy cập giao diện quản trị /admin
ADMIN_KEY=your_admin_secret_key_here

# --- Mạng & Hiệu suất ---
CORS_ORIGINS=*
REQUEST_TIMEOUT=60
RATE_LIMIT=30/minute

# --- Logging & Session ---
LOG_LEVEL=INFO
SESSION_TTL=3600

# --- Đường dẫn Node.js ---
# Đường dẫn đến bộ thực thi Node.js (bật nếu Node.js là portable)
# NODE_PATH=/home/container/nodejs/node-v20.10.0-linux-arm64/bin/node
